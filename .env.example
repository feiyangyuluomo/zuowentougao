# ============================================================================
# 数据库配置
# ============================================================================

# PostgreSQL 数据库连接 URL
DATABASE_URL="postgresql://user:password@localhost:5432/zuowentougao?schema=public"

# ============================================================================
# 数据源模式配置
# ============================================================================

# true = 使用 Mock 数据（开发模式，默认）
# false = 使用真实数据库
USE_MOCK=true

# ============================================================================
# 可选配置（未来扩展）
# ============================================================================

# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# 微信小程序配置
# WECHAT_APP_ID=
# WECHAT_SECRET=

# AI API 配置
# DEEPSEEK_API_KEY=
# WENXIN_API_KEY=

# 腾讯云 COS 配置
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=

# 腾讯云 OCR 配置
# OCR_SECRET_ID=
# OCR_SECRET_KEY=