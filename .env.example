# ============================================================================
# 数据库配置
# ============================================================================

# PostgreSQL 数据库连接 URL
# 格式: postgresql://user:password@host:port/database?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/zuowentougao?schema=public"

# ============================================================================
# 数据源模式配置
# ============================================================================

# true = 使用 Mock 数据（开发模式，默认）
# false = 使用真实数据库（需要 DATABASE_URL 有效）
USE_MOCK=true

# ============================================================================
# 说明
# ============================================================================

# USE_MOCK 行为：
# - USE_MOCK=true（默认）：所有 repository 读取 mock 数据
# - USE_MOCK=false：所有 repository 通过 Prisma 读取真实数据库
#
# 注意：USE_MOCK=false 时必须确保 DATABASE_URL 有效
#
# 运行数据库相关命令：
# - npm run db:push      # 同步 schema 到数据库（会清空数据，慎用）
# - npm run db:seed      # 填充种子数据
# - npm run db:smoke-test # 运行数据库 smoke test

# ============================================================================
# 可选配置（未来扩展）
# ============================================================================

# NEXTAUTH_SECRET=
# NEXTAUTH_URL=

# 微信小程序配置
# WECHAT_APP_ID=
# WECHAT_SECRET=

# AI API 配置
# DEEPSEEK_API_KEY=
# WENXIN_API_KEY=

# 腾讯云 COS 配置
# COS_SECRET_ID=
# COS_SECRET_KEY=
# COS_BUCKET=
# COS_REGION=

# 腾讯云 OCR 配置
# OCR_SECRET_ID=
# OCR_SECRET_KEY=